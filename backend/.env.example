# ========== DATABASE CONFIGURATION ==========
DATABASE_URL=postgresql://tridentwear_user:strong_password_here@localhost:5432/tridentwear_db

# ========== JWT CONFIGURATION ==========
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# ========== OTP CONFIGURATION ==========
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ========== RAZORPAY CONFIGURATION ==========
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ========== EMAIL CONFIGURATION ==========
# Use Gmail App Password (not your regular password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SENDER_EMAIL=noreply@tridentwear.com

# ========== APP CONFIGURATION ==========
APP_NAME=TridentWear API
APP_VERSION=1.0.0
DEBUG=False

# ========== CORS ORIGINS (comma-separated for production) ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://tridentwear.com
