# ─────────────────────────────────────────────────────────────────────
# TridentWear — Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ── Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))")
TRIDENT_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
TRIDENT_SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
TRIDENT_JWT_EXPIRATION_DAYS=7
TRIDENT_SESSION_MAX_AGE_SECONDS=604800
JWT_ALGORITHM=HS256

# ── CORS (comma-separated list of allowed frontend origins)
# Example: https://tridentwear.in,https://www.tridentwear.in
ALLOWED_ORIGINS=https://yourdomain.com

# ── OTP / Auth settings ──────────────────────────────────────────────
TRIDENT_OTP_PROVIDER=dev
TRIDENT_OTP_EXPIRY_MINUTES=5
TRIDENT_OTP_RESEND_SECONDS=45
TRIDENT_OTP_MAX_ATTEMPTS=5
TRIDENT_OTP_MAX_SENDS_PER_HOUR=5
TRIDENT_OTP_BLOCK_MINUTES=15

# ── Razorpay (REQUIRED for online payments) ──────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY=rzp_live_REPLACE_ME
RAZORPAY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME
TRIDENT_ENABLE_TEST_ORDERS=false

# ── Email / SMTP (for order confirmation emails) ─────────────────────
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use App Password if 2FA is enabled on Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# ── Database ─────────────────────────────────────────────────────────
# Use 'json' for file-based storage (default), 'postgres' for PostgreSQL
DB_MODE=json
# Only needed when DB_MODE=postgres:
# DATABASE_URL=postgresql://user:password@host:5432/tridentwear
# PG_DSN=postgresql://user:password@host:5432/tridentwear

# ── Optional: External API root override ─────────────────────────────
# Leave empty when frontend and backend are served from the same origin
TRIDENT_API_ROOT=
