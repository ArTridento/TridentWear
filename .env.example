# FastAPI
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Security
TRIDENT_JWT_SECRET=change-this-long-random-value-before-production
TRIDENT_SESSION_SECRET=change-this-long-random-session-value
TRIDENT_SESSION_MAX_AGE_SECONDS=604800
JWT_ALGORITHM=HS256

# Mobile OTP
TRIDENT_OTP_PROVIDER=dev
TRIDENT_OTP_EXPIRY_MINUTES=5
TRIDENT_OTP_RESEND_SECONDS=45
TRIDENT_OTP_MAX_ATTEMPTS=5
TRIDENT_OTP_MAX_SENDS_PER_HOUR=5
TRIDENT_OTP_BLOCK_MINUTES=15

# Payments
RAZORPAY_KEY=rzp_test_xxxxx
RAZORPAY_SECRET=replace-in-production
TRIDENT_ENABLE_TEST_ORDERS=true

# Email / SMS providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER_API_KEY=

# Data layer: json, postgres, or dual_write
DB_MODE=json
PG_DSN=postgresql://user:password@host:5432/tridentwear
DATABASE_URL=postgresql://user:password@host:5432/tridentwear

# Optional frontend override. Leave empty for same-origin production.
TRIDENT_API_ROOT=
